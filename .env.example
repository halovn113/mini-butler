# Butler v3 — .env.example
# cp .env.example .env  →  then fill in your values

# ── Ollama (required) ─────────────────────────────────────────────────────────
# Local inference (default):
BUTLER_OLLAMA_MODEL=llama3.1:8b
BUTLER_OLLAMA_BASE_URL=http://localhost:11434
BUTLER_OLLAMA_ROUTING_MODEL=
#
# Remote GPU VPS (compute offloading — #270):
#   1. Rent hourly GPU on RunPod / Vast.ai / Lambda (RTX 3090+ recommended)
#   2. Install Ollama on VPS:  curl -fsSL https://ollama.ai/install.sh | sh
#   3. Bind to localhost only:  OLLAMA_HOST=127.0.0.1 ollama serve
#   4. Pull model on VPS:       ollama pull qwen2.5:14b
#   5. Open SSH tunnel (local): ssh -N -L 11434:localhost:11434 root@<VPS_IP>
#      Or persistent service:   systemctl --user start butler-ssh-tunnel@<VPS_IP>
#   6. Set vars below, then:    butler --doctor   (validates connectivity + model)
#
# BUTLER_OLLAMA_MODEL=qwen2.5:14b
# BUTLER_OLLAMA_BASE_URL=http://localhost:11434   # tunnel makes remote appear local

# ── Vector Search ─────────────────────────────────────────────────────────────
BUTLER_VECTOR_SEARCH_WEIGHT=0.5

# ── Session Distillation ──────────────────────────────────────────────────────
BUTLER_DISTILLATION_ENABLED=true

# ── Vision / Remote VLM (optional — requires vlm_server.py running) ───────────
BUTLER_VLM_ENABLED=false
BUTLER_VLM_ENDPOINT=http://localhost:8090
BUTLER_VLM_TIMEOUT=5
BUTLER_SCREENSHOT_QUALITY=70

# ── Input Control (optional — mouse/keyboard automation) ──────────────────────
BUTLER_INPUT_CONTROL_ENABLED=false
BUTLER_INPUT_CONFIRM_DESTRUCTIVE=true
BUTLER_INPUT_TYPE_INTERVAL_MS=50

# ── Desktop Automation (#322 — AT-SPI tree + element interaction) ─────────────
BUTLER_DESKTOP_AUTOMATION_ENABLED=false

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which provider Butler uses for conversation.
# Options: ollama (local, default) | claude | openai | gemini
BUTLER_LLM_PROVIDER=ollama

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Models: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
BUTLER_ANTHROPIC_API_KEY=
BUTLER_ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI (or any OpenAI-compatible endpoint) ────────────────────────────────
# Models: gpt-4o | gpt-4o-mini | o3-mini
# BUTLER_OPENAI_BASE_URL can point at a local vLLM or LM Studio instance too.
BUTLER_OPENAI_API_KEY=
BUTLER_OPENAI_MODEL=gpt-4o-mini
BUTLER_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Gemini Flash 2.0 ──────────────────────────────────────────────────────────
BUTLER_GEMINI_ENABLED=false
BUTLER_GEMINI_API_KEY=
BUTLER_GEMINI_MODEL=gemini-2.0-flash

# ── Language / Translation ────────────────────────────────────────────────────
BUTLER_LANGUAGE=tr
BUTLER_TRANSLATION_ENABLED=true

# ── Shell Security ────────────────────────────────────────────────────────────
BUTLER_SHELL_CONFIRM_DESTRUCTIVE=true
BUTLER_SHELL_TIMEOUT_SECONDS=30

# ── Location (optional — auto-detected if empty) ─────────────────────────────
BUTLER_CITY=
BUTLER_REGION=
BUTLER_COUNTRY=TR
BUTLER_TIMEZONE=Europe/Istanbul
BUTLER_LAT=
BUTLER_LON=

# ── GPS Relay (optional — mobile GPS forwarding) ─────────────────────────────
BUTLER_GPS_RELAY_TOKEN=

# ── MemPalace Memory ─────────────────────────────────────────────────────────
BUTLER_MEMPALACE_ENABLED=true
BUTLER_PALACE_PATH=
BUTLER_MEMPALACE_KG_PATH=
BUTLER_MEMPALACE_WING=butler
BUTLER_MEMPALACE_IDENTITY_PATH=

# ── Storage (leave blank for ~/.local/share/butler) ────────────────────────────
BUTLER_DATA_DIR=

# ── Morning Briefing ─────────────────────────────────────────────────────────
BUTLER_MORNING_BRIEFING=true
BUTLER_MORNING_HOUR=8
BUTLER_MORNING_MINUTE=0

# ── Digests ───────────────────────────────────────────────────────────────────
BUTLER_DAILY_DIGEST_ENABLED=true
BUTLER_DAILY_DIGEST_HOUR=20
BUTLER_DAILY_DIGEST_MINUTE=0
BUTLER_WEEKLY_DIGEST_ENABLED=true
BUTLER_WEEKLY_DIGEST_DAY=sunday
BUTLER_WEEKLY_DIGEST_HOUR=20
BUTLER_WEEKLY_DIGEST_MINUTE=0

# ── Scheduler / Reminders ─────────────────────────────────────────────────────
BUTLER_REMINDER_CHECK_INTERVAL=30

# ── Job Scheduler / APScheduler (#128 — nightly maintenance, reflection) ──────
BUTLER_JOB_SCHEDULER_ENABLED=true
BUTLER_MAINTENANCE_HOUR=3
BUTLER_REFLECTION_HOUR=23
BUTLER_BRIEFING_PREP_HOUR=6
BUTLER_OVERNIGHT_POLL_HOURS=0,2,4,6

# ── Overnight Poll / Urgent Keywords (#132) ───────────────────────────────────
# Comma-separated keywords that mark an email as urgent (case-insensitive).
BUTLER_URGENT_KEYWORDS=urgent,acil,deadline,final,emergency,important

# ── Telegram Bot (optional — for notifications + remote control) ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_PROXY=
TELEGRAM_LLM_MODE=true

# ── Background Observer (#124 — proactive error detection) ────────────────────
BUTLER_OBSERVER_ENABLED=false
BUTLER_OBSERVER_SEVERITY_THRESHOLD=warning
BUTLER_OBSERVER_BATCH_SECONDS=5
BUTLER_OBSERVER_DEDUP_WINDOW=60
BUTLER_OBSERVER_ANALYSIS_MODEL=qwen2.5:0.5b
BUTLER_OBSERVER_ENABLE_LLM=true

# ── RL Engine (#125 — adaptive routine learning) ─────────────────────────────
BUTLER_RL_ENABLED=true
BUTLER_RL_LEARNING_RATE=0.3
BUTLER_RL_DISCOUNT_FACTOR=0.9
BUTLER_RL_EXPLORATION_RATE=0.15
BUTLER_RL_EXPLORATION_MIN=0.02
BUTLER_RL_CONFIDENCE_THRESHOLD=0.7
BUTLER_RL_SUGGESTION_INTERVAL=1800

# ── Bonding Meter (#172 — progressive formality reduction) ───────────────
BUTLER_BONDING_ENABLED=true
BUTLER_BONDING_SIGMOID_RATE=0.04
BUTLER_BONDING_SIGMOID_MIDPOINT=25

# ── Proactive Interventions (#126 — toast notifications) ─────────────────────
BUTLER_INTERVENTION_RATE_LIMIT=3
BUTLER_INTERVENTION_TOAST_TTL=20
BUTLER_INTERVENTION_QUIET_MODE=false
BUTLER_INTERVENTION_FOCUS_MODE=false

# ── App Detector (#127 — active window & workspace context) ──────────────
BUTLER_APP_DETECTOR_ENABLED=false
BUTLER_APP_DETECTOR_CACHE_TTL=5
BUTLER_APP_DETECTOR_POLLING_INTERVAL=5
BUTLER_APP_DETECTOR_AUTO_FOCUS=true

# ── Desktop Notifications (#153 — notify-send for interventions) ──────────
BUTLER_DESKTOP_NOTIFICATIONS=true
BUTLER_NOTIFICATION_ICON=
BUTLER_NOTIFICATION_SOUND=false

# ══════════════════════════════════════════════════════════════════════════
# VOICE PIPELINE (#277 — Master Switch)
# ══════════════════════════════════════════════════════════════════════════
# Setting BUTLER_VOICE_ENABLED=true turns on TTS, Wake Word, STT, Ghost Loop,
# Audio Ducking, and Ambient in one shot.  Individual flags below still
# override if you want fine-grained control.
#
# ⚠️  Linux prerequisite (Ubuntu/Mint/Debian):
#     sudo apt install portaudio19-dev
#   Without this, PyAudio (and therefore wake word + STT) will fail to install.
#
BUTLER_VOICE_ENABLED=false

# ── TTS / Audio Briefing (#131 — Piper text-to-speech) ───────────────────
BUTLER_TTS_ENABLED=false
# Sesi Danny'e zorla (eski lessac-medium yerine):
BUTLER_TTS_MODEL=en_US-danny-low
BUTLER_TTS_MODEL_PATH=
BUTLER_TTS_SPEAKER=0
BUTLER_TTS_RATE=1.0
BUTLER_TTS_AUTO_BRIEFING=true
# Her LLM cevabında konuşmasını açar:
BUTLER_TTS_SPEAK_ALL_RESPONSES=false
# Karanlık mekanik efekt (SoX pitch + reverb + overdrive):
BUTLER_TTS_ANIMATRONIC_FILTER=false
# Ses seviyesi artırımı — SoX gain (dB). 0 = kapalı, 12 = varsayılan boost:
BUTLER_TTS_GAIN=12.0

# ── Audio Ducking (#171 — lower other apps while TTS speaks) ────────────
# Requires pactl (PulseAudio/PipeWire).  Duck percentage = target volume
# for other apps (30 = 30%).  Butler's own aplay is excluded via PULSE_PROP.
BUTLER_AUDIO_DUCK_ENABLED=false
BUTLER_AUDIO_DUCK_PCT=30

# ── Wake Word Detection (#165 — "Hey Butler" via Porcupine) ──────────────
# Get a free access key at https://console.picovoice.ai/
BUTLER_WAKE_WORD_ENABLED=false
BUTLER_PICOVOICE_ACCESS_KEY=
BUTLER_WAKE_WORD_SENSITIVITY=0.5

# ── Ghost Loop / STT (#36 — hands-free voice input) ─────────────────
# Requires: pip install faster-whisper webrtcvad pyaudio
# Also requires wake word to be enabled (BUTLER_WAKE_WORD_ENABLED=true)
# Tip: BUTLER_VOICE_ENABLED=true sets all of these automatically.
# ⚠️  First run downloads the Whisper model from HuggingFace (~39 MB for tiny).
#     The TUI will show "Downloading Whisper model…" — this is normal.
BUTLER_GHOST_LOOP_ENABLED=true
BUTLER_STT_ENABLED=true
BUTLER_STT_MODEL=tiny
BUTLER_STT_LANGUAGE=en
BUTLER_STT_DEVICE=cpu
BUTLER_VAD_SILENCE_MS=800
BUTLER_VAD_AGGRESSIVENESS=2

# ── Ambient Sound Analysis (#166 — passive env classification) ───────────
# Piggybacks on wake word mic — requires BUTLER_WAKE_WORD_ENABLED=true
BUTLER_AMBIENT_ENABLED=false
BUTLER_AMBIENT_INTERVAL=600
BUTLER_AMBIENT_WINDOW=3.0

# ── Proactive Engagement (#167 — idle conversation initiation) ───────────
# Starts conservatively: 1 message/day, scales to 3 as RL earns rewards
BUTLER_PROACTIVE_ENABLED=false
BUTLER_PROACTIVE_INTERVAL_HOURS=3.0
BUTLER_PROACTIVE_JITTER_MINUTES=30
BUTLER_PROACTIVE_MAX_DAILY=1
BUTLER_PROACTIVE_AWAY_TIMEOUT=1800

# ── Health & Break Interventions (#168 — proactive health monitoring) ────
# 5-rule engine: late night load, marathon session, eye strain, thermal, music
BUTLER_HEALTH_ENABLED=false
BUTLER_HEALTH_CHECK_INTERVAL=300
BUTLER_HEALTH_LATE_HOUR=2
BUTLER_HEALTH_SESSION_MAX_HOURS=4.0
BUTLER_HEALTH_THERMAL_CPU=85.0
BUTLER_HEALTH_THERMAL_GPU=80.0
BUTLER_HEALTH_EYE_STRAIN_HOURS=2.0

# ── Dynamic Persona (#169 — 1920s butler character adaptation) ───────────
# Dynamically adjusts tone based on telemetry, time, activity, RL reward
BUTLER_PERSONA_ENABLED=true

# ── Deep Memory / Spontaneous Recall (#170) ──────────────────────────────
# Probabilistically surfaces relevant past memories during casual chat
BUTLER_DEEP_MEMORY_ENABLED=true
BUTLER_DEEP_MEMORY_THRESHOLD=0.72
BUTLER_DEEP_MEMORY_MAX_RESULTS=3

# Telegram Screenshot settings
TELEGRAM_SCREENSHOT_ENABLED=false
TELEGRAM_SCREENSHOT_QUALITY=75
TELEGRAM_SCREENSHOT_MAX_DIM=1920
SCREENSHOT_AUTO_AFTER_ACTION=false

# ── Multi-Agent Hierarchy (#321 — JARVIS-inspired sub-agents) ───────────────
# Enables delegate_task tool: the Brain can spin up Researcher, Developer,
# or Reviewer sub-agents for focused sub-tasks.
BUTLER_MULTI_AGENT_ENABLED=false
BUTLER_MULTI_AGENT_MAX_CONCURRENT=3
BUTLER_MULTI_AGENT_TIMEOUT=120

# ── Continuous Awareness (#325) ─────────────────────────────────────────────
# Captures active window, clipboard, and screenshot every N seconds.
# Injects desktop context into the system prompt automatically.
BUTLER_AWARENESS_ENABLED=true
BUTLER_AWARENESS_INTERVAL_S=15
# ── YAML Workflows (#323) ──────────────────────────────────────────────────
# Deterministic YAML workflow engine. Define multi-step pipelines in YAML
# and execute them via the run_workflow tool.
BUTLER_WORKFLOWS_ENABLED=true
BUTLER_WORKFLOWS_DIR=
BUTLER_TTS_LENGTH_SCALE=1.0
BUTLER_VLM_BACKEND=ollama
BUTLER_VLM_MODEL=llava
# Vision-guided executor model (Ollama name, or "gemini" for cloud fallback).
# Empty = ladder: llama3.2-vision:11b → moondream → gemini
BUTLER_VISION_MODEL=

# ── Personality dials ──────────────────────────────────────────────────────
# How chatty the butler is: silent | standard | insufferable
BUTLER_VERBOSITY=standard
# How freely Butler acts without confirmation: low | medium | high | absolute
BUTLER_AUTONOMY=high
# Default temperament: tolerant | impatient | resigned
BUTLER_MOOD_BIAS=tolerant
